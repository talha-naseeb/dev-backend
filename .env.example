# Server Configuration
PORT=5001
NODE_ENV=development

# Database
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/<dbname>?retryWrites=true&w=majority

# JWT
JWT_SECRET=<generate-a-strong-random-secret-min-32-chars>
JWT_EXPIRE=7d
JWT_RESET_EXPIRE=10m

# Admin Secret (used for super admin operations)
ADMIN_SECRET=<generate-a-strong-random-secret>

# Cloudinary (image uploads)
CLOUDINARY_CLOUD_NAME=<your-cloudinary-cloud-name>
CLOUDINARY_API_KEY=<your-cloudinary-api-key>
CLOUDINARY_API_SECRET=<your-cloudinary-api-secret>
CLOUDINARY_URL=cloudinary://<api-key>:<api-secret>@<cloud-name>

# Google OAuth
GOOGLE_CLIENT_ID=<from-google-cloud-console>
GOOGLE_CLIENT_SECRET=<from-google-cloud-console>
GOOGLE_CALLBACK_URL=http://localhost:5001/api/auth/google/callback

# Microsoft OAuth
MICROSOFT_CLIENT_ID=<from-azure-portal>
MICROSOFT_CLIENT_SECRET=<from-azure-portal>
MICROSOFT_CALLBACK_URL=http://localhost:5001/api/auth/microsoft/callback

# Email (SMTP)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=<your-gmail-address>
EMAIL_PASSWORD=<gmail-app-password-not-account-password>
EMAIL_FROM="Workspace Elite <your-email@gmail.com>"
SKIP_EMAIL_VERIFICATION=false

# Frontend URL (used for OAuth redirects and email links)
FRONTEND_URL=http://localhost:3000

# CORS (comma-separated allowed origins for production)
CLIENT_ORIGINS=http://localhost:3000

# Proxy hops (set to 1 behind Nginx/Railway/Vercel proxies)
# TRUST_PROXY_HOPS=1
